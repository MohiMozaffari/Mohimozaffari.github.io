# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/mohi-portfolio

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://mohimozaffari.github.io,http://localhost:3000

# Single-admin auth
ADMIN_USERNAME=mohi
ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=

# Shared secret for the external cron pinger hitting POST /api/sync/github
SYNC_SECRET=

# Optional but recommended: raises GitHub API rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=

# Resend (email forwarding for the contact form)
RESEND_API_KEY=
CONTACT_TO_EMAIL=mohaddeseh.mozaffarii@gmail.com

PORT=5000
