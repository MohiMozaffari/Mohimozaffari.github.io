{
  "name": "mohaddeseh-mozaffari-website-worker",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute mohi-portfolio --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute mohi-portfolio --remote --file=./schema.sql",
    "db:seed:remote": "wrangler d1 execute mohi-portfolio --remote --file=./seed.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "hono": "^4.6.9"
  },
  "devDependencies": {
    "wrangler": "^4.110.0"
  }
}
